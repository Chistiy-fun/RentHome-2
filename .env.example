## ─── Django Backend ───────────────────────────────────────────────────────────
#DJANGO_SECRET_KEY=django-insecure-change-this-to-a-long-random-string
#DEBUG=True
#ALLOWED_HOSTS=localhost,127.0.0.1,backend
#
## ─── Telegram Bot ─────────────────────────────────────────────────────────────
## Get from @BotFather
#BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
#
## Your Telegram user ID (get from @userinfobot)
#ADMIN_TELEGRAM_ID=123456789
#
## Bot username (without @)
#BOT_USERNAME=YourRentHomeBot
#
## ─── Telegram Payments ────────────────────────────────────────────────────────
## Get TEST token from @BotFather → Payments → Connect provider (Stripe TEST)
## Leave empty to use MOCK mode (no real payments)
#TELEGRAM_PAYMENT_PROVIDER_TOKEN=
#
## Set to 'false' to use real Telegram Payments (requires TELEGRAM_PAYMENT_PROVIDER_TOKEN)
#MOCK_PAYMENTS=true
#
## ─── Internal ────────────────────────────────────────────────────────────────
#BACKEND_URL=http://backend:8000
